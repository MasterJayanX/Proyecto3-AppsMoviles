<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Gastos.ViewModels"
             x:Class="Gastos.SecondPage"
             x:DataType="vm:TransactionEntryViewModel"
             BackgroundColor="White"
             Title="GASTOS">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <!-- Título -->
            <Label Text="Nueva transacción"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#1A1A2E"
                   Margin="0,10,0,10" />

            <!-- Tarjeta del formulario -->
            <Border StrokeThickness="0"
                    Padding="24"
                    BackgroundColor="White">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Gray" Offset="0,4" Radius="16" Opacity="0.12" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="18">

                    <!-- Glosa -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Glosa"
                               TextColor="#9E9E9E"
                               FontSize="14" />
                        <Border StrokeThickness="1.5"
                                Stroke="#7C3AED"
                                BackgroundColor="White"
                                Padding="10,8">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Entry Text="{Binding Glosa, Mode=TwoWay}"
                                   Placeholder=""
                                   TextColor="#1A1A2E"
                                   BackgroundColor="Transparent" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Cantidad -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Cantidad"
                               TextColor="#9E9E9E"
                               FontSize="14" />
                        <Border StrokeThickness="1.5"
                                Stroke="#7C3AED"
                                BackgroundColor="White"
                                Padding="10,8">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Entry Text="{Binding Cantidad, Mode=TwoWay}"
                                   Keyboard="Numeric"
                                   Placeholder="0"
                                   TextColor="#1A1A2E"
                                   BackgroundColor="Transparent" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Fecha -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Fecha"
                               TextColor="#9E9E9E"
                               FontSize="14" />
                        <Border StrokeThickness="1.5"
                                Stroke="#7C3AED"
                                BackgroundColor="White"
                                Padding="10,4">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <DatePicker Date="{Binding FechaSeleccionada, Mode=TwoWay}"
                                        TextColor="#1A1A2E"
                                        BackgroundColor="Transparent" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Checkbox ¿Es ingreso? -->
                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <CheckBox IsChecked="{Binding EsIngreso, Mode=TwoWay}"
                                  Color="#7C3AED" />
                        <Label Text="¿Es ingreso?"
                               TextColor="#1A1A2E"
                               FontSize="15"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Botones -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,6,0,0">
                        <Button Text="Guardar"
                                Command="{Binding GuardarCommand}"
                                BackgroundColor="#5C27D9"
                                TextColor="White"
                                CornerRadius="14"
                                FontAttributes="Bold" />
                        <Button Grid.Column="1"
                                Text="Cancelar"
                                Command="{Binding CancelarCommand}"
                                BackgroundColor="#C0392B"
                                TextColor="White"
                                CornerRadius="14"
                                FontAttributes="Bold" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>