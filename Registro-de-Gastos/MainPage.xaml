<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Gastos.Models"
             xmlns:vm="clr-namespace:Gastos.ViewModels"
             x:Class="Gastos.MainPage"
             x:DataType="vm:HomeViewModel"
             BackgroundColor="White"
             Title="GASTOS">

    <Grid RowDefinitions="Auto,*">

        <!-- Encabezado morado -->
        <VerticalStackLayout Grid.Row="0"
                             BackgroundColor="#4A148C"
                             Padding="20,40,20,60"
                             Spacing="4">
            <Label Text="Hola,"
                   TextColor="#E1BEE7"
                   FontSize="16" />
            <Label Text="Usuario"
                   TextColor="White"
                   FontSize="26"
                   FontAttributes="Bold" />
        </VerticalStackLayout>

        <!-- Contenido principal con scroll -->
        <ScrollView Grid.Row="1" Margin="0,-44,0,0">
            <VerticalStackLayout Padding="16,0,16,24" Spacing="18">

                <!-- Tarjeta de balance (superpuesta sobre el encabezado) -->
                <Border StrokeThickness="0"
                        Padding="20,18"
                        BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Gray" Offset="0,4" Radius="16" Opacity="0.15" />
                    </Border.Shadow>

                    <Grid RowDefinitions="Auto,Auto,Auto"
                          ColumnDefinitions="*,*,Auto">

                        <!-- Balance -->
                        <Label Grid.Row="0" Grid.ColumnSpan="2"
                               Text="Balance"
                               TextColor="#9E9E9E"
                               FontSize="14" />
                        <Label Grid.Row="1" Grid.ColumnSpan="2"
                               Text="{Binding TotalDisponibleTexto}"
                               TextColor="#1A1A2E"
                               FontSize="26"
                               FontAttributes="Bold"
                               Margin="0,0,0,10" />

                        <!-- Ingresos -->
                        <VerticalStackLayout Grid.Row="2" Grid.Column="0" Spacing="2">
                            <Label Text="Ingresos"
                                   TextColor="#9E9E9E"
                                   FontSize="13" />
                            <Label Text="{Binding IngresosTexto}"
                                   TextColor="#1A1A2E"
                                   FontSize="18"
                                   FontAttributes="Bold" />
                        </VerticalStackLayout>

                        <!-- Egresos -->
                        <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="2">
                            <Label Text="Egresos"
                                   TextColor="#9E9E9E"
                                   FontSize="13" />
                            <Label Text="{Binding EgresosTexto}"
                                   TextColor="#1A1A2E"
                                   FontSize="18"
                                   FontAttributes="Bold" />
                        </VerticalStackLayout>

                        <!-- Botón + flotante en la tarjeta -->
                        <Button Grid.Row="2" Grid.Column="2"
                                Text="+"
                                Command="{Binding IrACrearMovimientoCommand}"
                                BackgroundColor="#4A148C"
                                TextColor="White"
                                CornerRadius="28"
                                WidthRequest="56"
                                HeightRequest="56"
                                FontSize="28"
                                VerticalOptions="End"
                                Margin="8,0,8,0" />
                    </Grid>
                </Border>

                <!-- Título de la lista -->
                <Label Text="Transacciones"
                       TextColor="#9E9E9E"
                       FontSize="14"
                       Margin="4,0,0,0" />

                <!-- Lista de transacciones -->
                <CollectionView ItemsSource="{Binding Movimientos}"
                                SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Label Text="Sin datos, click en el botón + para agregar una nueva transacción"
                               TextColor="#9E9E9E"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               Margin="0,30,0,0" />
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:FinancialTransaction">
                            <Grid ColumnDefinitions="*,Auto"
                                  Padding="4,10,4,10">
                                <!-- Separador superior -->
                                <BoxView Grid.ColumnSpan="2"
                                         HeightRequest="1"
                                         Color="#F0F0F0"
                                         VerticalOptions="Start" />

                                <!-- Nombre y fecha -->
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{Binding Description}"
                                           TextColor="#1A1A2E"
                                           FontAttributes="Bold"
                                           FontSize="15" />
                                    <Label Text="{Binding CreatedAtLabel}"
                                           TextColor="#9E9E9E"
                                           FontSize="13" />
                                </VerticalStackLayout>

                                <!-- Monto coloreado -->
                                <Label Grid.Column="1"
                                       Text="{Binding AmountLabel}"
                                       TextColor="{Binding TypeColor}"
                                       FontAttributes="Bold"
                                       FontSize="16"
                                       VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
