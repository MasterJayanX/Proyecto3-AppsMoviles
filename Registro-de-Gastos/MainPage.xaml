<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Gastos.Models"
             xmlns:vm="clr-namespace:Gastos.ViewModels"
             x:Class="Gastos.MainPage"
             x:DataType="vm:HomeViewModel"
             BackgroundColor="#0B1220"
             Title="Home">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">

            <Border StrokeThickness="0" Padding="24">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#10233F" Offset="0" />
                        <GradientStop Color="#0F4C5C" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Spacing="12">
                    <Label Text="Banco personal" TextColor="#9FD7E4" FontSize="14" />
                    <Label Text="Saldo disponible" TextColor="White" FontSize="18" />
                    <Label Text="{Binding TotalDisponibleTexto}" TextColor="White" FontAttributes="Bold" FontSize="44" />
                    <Label Text="{Binding ResumenTexto}" TextColor="#D0E7EF" FontSize="14" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Border BackgroundColor="#10263A" StrokeThickness="0" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Ingresos" TextColor="#8BD3C7" FontSize="13" />
                        <Label Text="{Binding IngresosTexto}" TextColor="White" FontAttributes="Bold" FontSize="24" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" BackgroundColor="#2A1E2F" StrokeThickness="0" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Egresos" TextColor="#F5A3B7" FontSize="13" />
                        <Label Text="{Binding EgresosTexto}" TextColor="White" FontAttributes="Bold" FontSize="24" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                <Label Text="Historial de movimientos" TextColor="White" FontAttributes="Bold" FontSize="18" />
                <Button Grid.Column="1" Text="Nuevo movimiento" Command="{Binding IrACrearMovimientoCommand}" BackgroundColor="#2B8DFF" TextColor="White" CornerRadius="14" />
            </Grid>

            <CollectionView ItemsSource="{Binding Movimientos}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <Border BackgroundColor="#121A2A" StrokeThickness="0" Padding="20">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Label Text="Aún no hay ingresos ni egresos registrados." TextColor="#9EB4C4" />
                    </Border>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:FinancialTransaction">
                        <Border BackgroundColor="#111A2A" StrokeThickness="0" Padding="16" Margin="0,0,0,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12">
                                <Border BackgroundColor="{Binding TypeColor}" StrokeThickness="0" WidthRequest="12" HeightRequest="12" VerticalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="6" />
                                    </Border.StrokeShape>
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="{Binding MovementTypeLabel}" TextColor="White" FontAttributes="Bold" />
                                    <Label Text="{Binding CreatedAtLabel}" TextColor="#90A4B7" FontSize="12" />
                                    <Label Text="{Binding Description}" TextColor="#D0E7EF" FontSize="12" LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>

                                <Label Grid.Column="2" Text="{Binding AmountLabel}" TextColor="White" FontAttributes="Bold" FontSize="18" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
